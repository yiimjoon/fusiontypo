						Center = Input {
							Expression = "Point(iif(Text1.Direction == 2, 0.5 - ((1 - IntroMotion.Value) * 1.1), iif(Text1.Direction == 3, 0.5 + ((1 - IntroMotion.Value) * 1.1), 0.5)), iif(Text1.Direction == 0, 0.5 - ((1 - IntroMotion.Value) * 1.1), iif(Text1.Direction == 1, 0.5 + ((1 - IntroMotion.Value) * 1.1), 0.5)))",
						},
						Width = Input {
							Expression = "iif(Text1.Direction == 2, 0.001 + (IntroMotion.Value * 2.2), iif(Text1.Direction == 3, 0.001 + (IntroMotion.Value * 2.2), 2.2))",
						},
						Height = Input {
							Expression = "iif(Text1.Direction == 0, 0.001 + (IntroMotion.Value * 2.2), iif(Text1.Direction == 1, 0.001 + (IntroMotion.Value * 2.2), 2.2))",
						},
						SoftEdge = Input { Value = 0.008, },
					},
