						},
						Opacity1 = Input {
							Expression = "IntroMotion.Value * (1 - OutroRamp.Value)",
						},
						Offset1 = Input {
							Expression = "Point(-0.5 + (((Text1.Direction == 2) and -1 or (Text1.Direction == 3) and 1 or 0) * (1 - IntroMotion.Value) * Text1.TravelDistance), -0.5 + (((Text1.Direction == 0) and -1 or (Text1.Direction == 1) and 1 or 0) * (1 - IntroMotion.Value) * Text1.TravelDistance))",
