					Inputs = {
						Source = Input { Value = FuID { "Duration" }, },
						Curve = Input { Value = FuID { "Custom" }, },
						Lookup = Input {
							SourceOp = "IntroBlurLookup",
							Source = "Value",
						},
						Scale = Input { Value = 4, },
					},
				},
				IntroBlurLookup = LUTBezier {
					KeyColorSplines = {
						[0] = {
							[0] = { 1, RH = { 0.0733333333333333, 1 }, Flags = { Linear = true } },
							[0.22] = { 0, LH = { 0.146666666666667, 0 }, RH = { 0.48, 0 }, Flags = { Linear = true } },
							[1] = { 0, LH = { 0.74, 0 }, Flags = { Linear = true } }
						}
					},
					SplineColor = { Red = 255, Green = 255, Blue = 255 },
				},
				OutroRamp = LUTLookup {
					CtrlWZoom = false,
					Inputs = {
						Source = Input { Value = FuID { "Duration" }, },
						Lookup = Input {
							SourceOp = "LinearLookup",
							Source = "Value",
						},
						Scale = Input {
							Expression = "1 / iif(Text1.OutroLength < 0.01, 0.01, Text1.OutroLength)",
						},
						Offset = Input {
							Expression = "1 - (1 / iif(Text1.OutroLength < 0.01, 0.01, Text1.OutroLength))",
						},
					},
				}
			},
